<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <View
        android:id="@+id/itemTelegramProtocolDot"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:background="@drawable/bg_circle"
        android:backgroundTint="#2AABEE" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/itemTelegramTitle"
            style="@style/Widget.Vector.TextView.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?vctr_content_primary"
            tools:text="Channel Name" />

        <TextView
            android:id="@+id/itemTelegramLastMsg"
            style="@style/Widget.Vector.TextView.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?vctr_content_secondary"
            tools:text="Last message preview…" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/itemTelegramTime"
            style="@style/Widget.Vector.TextView.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?vctr_content_secondary"
            tools:text="12:34" />

        <TextView
            android:id="@+id/itemTelegramUnread"
            style="@style/Widget.Vector.TextView.Caption"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="?colorPrimary"
            android:gravity="center"
            android:textColor="?colorOnPrimary"
            android:visibility="gone"
            tools:text="3"
            tools:visibility="visible" />

    </LinearLayout>

</LinearLayout>
