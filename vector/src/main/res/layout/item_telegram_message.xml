<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:layout_marginTop="2dp"
    android:layout_marginBottom="2dp">

    <LinearLayout
        android:id="@+id/itemTgMsgBubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="280dp"
        android:orientation="vertical"
        android:background="@drawable/rounded_rect_shape_8"
        android:padding="10dp">

        <TextView
            android:id="@+id/itemTgMsgText"
            style="@style/Widget.Vector.TextView.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?vctr_content_primary"
            tools:text="Hello! How are you?" />

        <!-- Link preview card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/itemTgMsgWebPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:cardCornerRadius="6dp"
            app:cardElevation="1dp"
            tools:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <View
                    android:id="@+id/itemTgMsgWebPreviewImage"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/itemTgMsgWebPreviewTitle"
                    style="@style/Widget.Vector.TextView.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:textColor="?vctr_content_primary"
                    android:maxLines="2" />

                <TextView
                    android:id="@+id/itemTgMsgWebPreviewDesc"
                    style="@style/Widget.Vector.TextView.Caption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="8dp"
                    android:textColor="?vctr_content_secondary"
                    android:maxLines="2" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bot keyboard buttons -->
        <LinearLayout
            android:id="@+id/itemTgMsgKeyboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/itemTgMsgTime"
            style="@style/Widget.Vector.TextView.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="?vctr_content_quaternary"
            tools:text="12:34" />

    </LinearLayout>

</LinearLayout>
